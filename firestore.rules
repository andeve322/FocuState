rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: owner may read their document and update profile fields,
    // but client updates may NOT modify `storageUsageBytes` (server-only).
    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      // Disallow any client update that attempts to change storageUsageBytes.
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && (
                      // Either the update does not include storageUsageBytes
                      !request.resource.data.keys().hasAny(['storageUsageBytes'])
                      // Or, if it does, the value must remain equal to the existing value
                      || request.resource.data.storageUsageBytes == resource.data.storageUsageBytes
                    );

      // Allow owner read/write to subcollections
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Username availability + reservation
    match /usernames/{name} {
      allow get: if true;
      allow create, update, delete: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // Leaderboards: everyone can read; authenticated users may write
    match /leaderboards/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: allow reads by owner; restrict client writes so that
    // `storageUsageBytes` is server-only (cannot be modified by clients).
    match /users/{userId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      // Allow the owner to read their document
      allow get, list: if isOwner();

      // Allow creating own user doc (signup flows)
      allow create: if isOwner();

      // Disallow client-side deletes of user doc
      allow delete: if false;

      // Allow updates by the owner but prevent changing `storageUsageBytes` (server-only)
      allow update: if isOwner() && isValidUserUpdate();

      // Helper: ensure client update does not modify server-only fields and
      // only changes a limited, safe set of keys. Adjust allowedKeys to your schema.
      function isValidUserUpdate() {
        // Prevent any change to storageUsageBytes by requiring it to remain equal
        // to the existing value (resource.data is the current doc before write).
        if (request.resource.data.keys().hasAny(['storageUsageBytes'])) {
          if (request.resource.data.storageUsageBytes != resource.data.storageUsageBytes) {
            return false;
          }
        }

        // Allow only known profile fields to be changed by clients.
        // Add or remove keys here as appropriate for your app.
        let allowedKeys = [
          'username', 'usernameLower', 'updatedAt', 'flowTier',
          'subscriptionStatus', 'autoSyncEnabled', 'leaderboardOptIn', 'storageQuotaBytes'
        ];

        // Permit server-side fields already present to remain untouched.
        return request.resource.data.keys().hasOnly(resource.data.keys().union(allowedKeys))
               // Basic typing guards for a couple of fields
               && (request.resource.data.storageQuotaBytes is number || !(request.resource.data.keys().hasAny(['storageQuotaBytes'])))
               && (request.resource.data.autoSyncEnabled is bool || !(request.resource.data.keys().hasAny(['autoSyncEnabled'])));
      }

      // Subcollections under users/{userId} — owner may read/write their subtree
      match /{document=**} {
        allow read, write: if isOwner();
      }
    }

    // Username availability + reservation
    match /usernames/{name} {
      allow get: if true;
      allow create, update, delete: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // Leaderboards: everyone can read; authenticated users may write their own entries
    match /leaderboards/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
